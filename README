# Comandos Utilizados

Backend (Node + Express + Sequelize)

# Crear y entrar a la carpeta del backend
mkdir backend
cd backend

# Inicializar proyecto
npm init -y

# Instalar dependencias principales
npm install express sequelize mysql2 dotenv cors bcryptjs jsonwebtoken nodemailer multer axios cheerio form-data @getbrevo/brevo
npm install sharp
npm install bcrypt
npm install pdfkit

# Instalar dependencias de desarrollo
npm install -D nodemon

# Crear estructura de carpetas
mkdir src
cd src
mkdir config models routes controllers middlewares services
cd ..



Frontend (React + Vite)

# Crear y entrar a la carpeta del frontend
cd ..
mkdir frontend
cd frontend

# Crear proyecto con Vite
npm create vite@latest . -- --template react

# Instalar dependencias
npm install axios react-router-dom

# Crear estructura de carpetas
cd src
mkdir components pages services styles
cd components
mkdir common registro ui
cd ../pages
mkdir publicas admin arrendador arrendatario
cd ../..


